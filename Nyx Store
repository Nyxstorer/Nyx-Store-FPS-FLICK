local isDragging = false

local function GetColorAt(relative)
	local keys = gradient.Color.Keypoints
	local count = #keys
	local scaled = relative * (count - 1)
	local index = math.floor(scaled) + 1
	local frac = scaled - math.floor(scaled)
	if index >= count then return keys[count].Value end
	local c1 = keys[index].Value
	local c2 = keys[math.min(index + 1, count)].Value
	return c1:Lerp(c2, frac)
end

