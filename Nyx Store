local function CreateSlider(parent, text, y, min, max, default, callback, isInteger)
	local container = Instance.new("Frame")
	container.Parent = parent
	container.Size = UDim2.new(0.9, 0, 0, 50)
	container.Position = UDim2.fromOffset(15, y)
	container.BackgroundColor3 = Color3.fromRGB(35,35,35)
	Instance.new("UICorner", container).CornerRadius = UDim.new(0, 8)
	
	local label = Instance.new("TextLabel")
	label.Parent = container
	label.Size = UDim2.new(1, -20, 0, 20)
	label.Position = UDim2.fromOffset(10, 5)
	label.BackgroundTransparency = 1
	label.Text = text .. ": " .. default
	label.TextColor3 = Color3.new(1,1,1)
	label.Font = Enum.Font.Gotham
	label.TextSize = 12
	label.TextXAlignment = Enum.TextXAlignment.Left
	
	local track = Instance.new("Frame")
	track.Parent = container
	track.Position = UDim2.fromOffset(10, 28)
	track.Size = UDim2.new(1, -20, 0, 6)
	track.BackgroundColor3 = Color3.fromRGB(60,60,60)
	Instance.new("UICorner", track).CornerRadius = UDim.new(0, 3)
	
	local fill = Instance.new("Frame")
	fill.Parent = track
	fill.BackgroundColor3 = Color3.fromRGB(200,0,0)
	fill.Size = UDim2.fromScale((default-min)/(max-min), 1)
	Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 3)
	
	local thumb = Instance.new("Frame")
	thumb.Parent = track
	thumb.Size = UDim2.fromOffset(14, 14)
	thumb.Position = UDim2.new((default-min)/(max-min), -7, 0.5, -7)
	thumb.BackgroundColor3 = Color3.fromRGB(255,255,255)
	Instance.new("UICorner", thumb).CornerRadius = UDim.new(1, 0)
	
	local glow = Instance.new("ImageLabel")
	glow.Parent = thumb
	glow.Size = UDim2.new(1.5, 0, 1.5, 0)
	glow.Position = UDim2.new(-0.25, 0, -0.25, 0)
	glow.BackgroundTransparency = 1
	glow.Image = "rbxassetid://131326158033007"
	glow.ImageColor3 = Color3.fromRGB(200,0,0)
	glow.ImageTransparency = 0.7
	
	local dragging = false
	
	local clickArea = Instance.new("TextButton")
	clickArea.Parent = container
	clickArea.Position = UDim2.fromOffset(10, 25)
	clickArea.Size = UDim2.new(1, -20, 0, 15)
	clickArea.BackgroundTransparency = 1
	clickArea.Text = ""
	
	local function UpdateValue(relativeX)
		local clamped = math.clamp(relativeX, 0, 1)
		fill.Size = UDim2.fromScale(clamped, 1)
		thumb.Position = UDim2.new(clamped, -7, 0.5, -7)
		
		local value = min + (max - min) * clamped
		if isInteger then value = math.floor(value + 0.5) end
		
		label.Text = text .. ": " .. (isInteger and value or string.format("%.2f", value))
		callback(value)
	end
	
	clickArea.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = true
			Panel.Draggable = false
			local x = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
			UpdateValue(x)
		end
	end)
	
	UIS.InputChanged:Connect(function(input)
		if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
			local x = (input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X
			UpdateValue(x)
		end
	end)
	
	UIS.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
			dragging = false
			Panel.Draggable = true
		end
	end)
end

