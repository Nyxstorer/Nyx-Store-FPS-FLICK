local FOV = Drawing.new("Circle")
FOV.Thickness = 2
FOV.NumSides = 64
FOV.Filled = false
FOV.Visible = false

local function ClearVision(part, char)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Exclude
	params.FilterDescendantsInstances = {Player.Character, Camera}
	local dir = (part.Position - Camera.CFrame.Position).Unit * 5000
	local ray = workspace:Raycast(Camera.CFrame.Position, dir, params)
	return not ray or ray.Instance:IsDescendantOf(char)
end

local function GetTarget()
	local closest, dist = nil, State.FOVSize
	local center = Camera.ViewportSize / 2
	for _, plr in Players:GetPlayers() do
		if plr ~= Player and plr.Character and plr.Character:FindFirstChild("Head") then
			local hum = plr.Character:FindFirstChildOfClass("Humanoid")
			if hum and hum.Health > 0 then
				local head = plr.Character.Head
				local screenPos, onScreen = Camera:WorldToViewportPoint(head.Position)
				if onScreen then
					local mag = (Vector2.new(screenPos.X, screenPos.Y) - center).Magnitude
					if mag < dist then
						if not State.WallCheck or ClearVision(head, plr.Character) then
							dist = mag
							closest = head
						end
					end
				end
			end
		end
	end
	return closest
end

local ESPTable = {}
local hue = 0

local function hsvToRGB(h, s, v)
	h = h % 1
	local r, g, b = v, v, v
	if s > 0 then
		local i = math.floor(h * 6)
		local f = h * 6 - i
		local p = v * (1 - s)
		local q = v * (1 - f * s)
		local t = v * (1 - (1 - f) * s)
		if i == 0 then r,g,b = v,t,p
		elseif i == 1 then r,g,b = q,v,p
		elseif i == 2 then r,g,b = p,v,t
		elseif i == 3 then r,g,b = p,q,v
		elseif i == 4 then r,g,b = t,p,v
		else r,g,b = v,p,q end
	end
	return Color3.new(r,g,b)
end

local function NewESP(plr)
	if plr == Player then return end
	local box = Drawing.new("Square")
	box.Thickness = 1
	box.Filled = false
	box.Color = Color3.fromRGB(255,0,0)

	local name = Drawing.new("Text")
	name.Center = true
	name.Outline = true
	name.Size = 13
	name.Color = Color3.new(1,1,1)

	local dist = Drawing.new("Text")
	dist.Center = true
	dist.Outline = true
	dist.Size = 12
	dist.Color = Color3.new(1,1,1)

	local tracer = Drawing.new("Line")
	tracer.Thickness = 1
	tracer.Color = Color3.fromRGB(255,0,0)

	ESPTable[plr] = {box = box, name = name, dist = dist, tracer = tracer}
end

for _, p in Players:GetPlayers() do NewESP(p) end
Players.PlayerAdded:Connect(NewESP)
Players.PlayerRemoving:Connect(function(p)
	if ESPTable[p] then
		for _, v in ESPTable[p] do v:Remove() end
		ESPTable[p] = nil
	end
end)

--------------------------------------------------
-- RENDER LOOP (Nome só aparece quando State.ShowName = true)
--------------------------------------------------
RunService.RenderStepped:Connect(function(dt)
	FOV.Position = Camera.ViewportSize/2
	FOV.Radius = State.FOVSize
	FOV.Visible = State.ShowFOV

	if State.AssistAim then
		local target = GetTarget()
		if target then
			local currentLook = Camera.CFrame.LookVector
			local desiredLook = (target.Position - Camera.CFrame.Position).Unit
			local smoothedLook = currentLook:Lerp(desiredLook, dt * 80)
			Camera.CFrame = CFrame.new(Camera.CFrame.Position, Camera.CFrame.Position + smoothedLook)
		end
	end

	local currentColor = State.RGB and hsvToRGB((hue + dt * State.RGB_Speed) % 1, 1, 1) or State.CustomColor
	hue = (hue + dt * State.RGB_Speed) % 1

	FOV.Color = currentColor

	for _, obj in ESPTable do
		obj.box.Color = currentColor
		obj.tracer.Color = currentColor
		if State.RGB then
			obj.name.Color = currentColor
			obj.dist.Color = currentColor
		else
			obj.name.Color = Color3.new(1,1,1)
			obj.dist.Color = Color3.new(1,1,1)
		end
	end

	local bottom = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y - 15)

	for plr, obj in ESPTable do
		if State.ESP and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
			local root = plr.Character.HumanoidRootPart
			local pos, visible = Camera:WorldToViewportPoint(root.Position)

			if visible then
				local distance = math.floor((root.Position - Camera.CFrame.Position).Magnitude)

				obj.box.Visible = true
				obj.box.Size = Vector2.new(1400 / (distance + 5), 2000 / (distance + 5))
				obj.box.Position = Vector2.new(pos.X - obj.box.Size.X/2, pos.Y - obj.box.Size.Y/2)

				-- Nome (só aparece quando ativado)
				obj.name.Visible = State.ShowName
				obj.name.Text = plr.Name
				obj.name.Position = Vector2.new(pos.X, pos.Y - obj.box.Size.Y/2 - 16)

				obj.dist.Visible = true
				obj.dist.Text = distance .. "m"
				obj.dist.Position = Vector2.new(pos.X, pos.Y + obj.box.Size.Y/2 + 4)

				obj.tracer.Visible = State.Tracer
				if State.Tracer then
					obj.tracer.From = bottom
					obj.tracer.To = Vector2.new(pos.X, pos.Y)
				end
			else
				for _, v in obj do v.Visible = false end
			end
		else
			for _, v in obj do v.Visible = false end
		end
	end
end)

